# rentfit-v1-be base URL (no trailing slash). Must match CORS_ORIGIN on the API.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Canonical site URL for metadata, Open Graph, and absolute favicon URLs (no trailing slash).
# On Vercel production, set to https://your-app.vercel.app (or custom domain). If unset, VERCEL_URL is used at build time.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
